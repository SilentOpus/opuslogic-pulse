# Pulse connects to OpusLogic services on the shared opuslogic_default network.

# Platform service endpoints
PULSE_BACKEND_URL=https://backend:7443
PULSE_ZITADEL_URL=http://zitadel:8080
PULSE_TEMPORAL_URL=temporal-server:7233
PULSE_POSTGRES_DSN=postgresql://flows_user:CHANGEME@postgres:5432/flows

# Public hostname + email for Let's Encrypt
LE_EMAIL=ali@opuslogic.eu

# OIDC — fill in after running ./scripts/setup-zitadel-pulse.sh
VITE_OIDC_AUTHORITY=https://auth.opuslogic.eu
VITE_OIDC_CLIENT_ID=REPLACE_ME
OIDC_ISSUER=https://auth.opuslogic.eu
OIDC_JWKS_URI=https://auth.opuslogic.eu/oauth/v2/keys
OIDC_PROJECT_ID=REPLACE_ME
