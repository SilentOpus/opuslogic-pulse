# Pulse connects to OpusLogic services on the shared opuslogic_default network.
# Fill in the Postgres DSN with the same credentials the platform uses.

PULSE_BACKEND_URL=https://backend:7443
PULSE_ZITADEL_URL=http://zitadel:8080
PULSE_TEMPORAL_URL=temporal-server:7233
PULSE_POSTGRES_DSN=postgresql://flows_user:CHANGEME@postgres:5432/flows
